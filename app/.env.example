# Clerk Authentication (required)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Supabase Database (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# E2E Test Mode (optional - set to true to enable mock auth for E2E testing in non-production environments)
E2E_TEST_MODE=false

# Staging Smoke Testing (optional - credentials to run Playwright E2E tests against real remote staging deployments)
E2E_BASE_URL=https://legal-matters-two.vercel.app
E2E_CLERK_EMAIL=user@example.com
E2E_CLERK_PASSWORD=secure_password

