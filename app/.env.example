# ============================================================
# Legal Matters - Environment Variables Template
# Copy this file to .env.local for local development
# NEVER commit .env.local to git
# ============================================================

# Application URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# Supabase Connection (REQUIRED)
# Get these from: https://app.supabase.com → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - server-side only (never expose to browser)
# Required for admin operations (user registration, audit logs)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# South African Legal Constants
# ============================================================
NEXT_PUBLIC_VAT_RATE_PERCENT=15.00
NEXT_PUBLIC_DEFAULT_TIMEZONE=Africa/Johannesburg
NEXT_PUBLIC_DEFAULT_LOCALE=en_ZA

# ============================================================
# PII Encryption Key (AES-256)
# Must be exactly 64 hex characters (32 bytes)
# Generate with: openssl rand -hex 32
# ============================================================
ENCRYPTION_SECRET_KEY=your-64-hex-char-encryption-key-here

# ============================================================
# Test/Playwright Environment Flag
# Set to 'true' ONLY for Playwright E2E test runs
# NEVER set in Vercel staging or production environments
# This is handled automatically by playwright.config.ts
# ============================================================
# NEXT_PUBLIC_TEST_MODE=false

# ============================================================
# STAGING ENVIRONMENT NOTE
# DO NOT set NODE_ENV manually in Vercel or any .env file.
# Vercel automatically sets NODE_ENV=production for all deployments.
# For environment differentiation, use:
#   NEXT_PUBLIC_APP_ENV=staging  (or production)
# ============================================================
# NEXT_PUBLIC_APP_ENV=staging
